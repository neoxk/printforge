generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OptionType {
  select
  boolean
  integer
  decimal

  @@map("option_type")
}

enum PricingRuleType {
  flat_surcharge
  percentage
  quantity_discount

  @@map("pricing_rule_type")
}

enum PricingRuleOperator {
  eq
  gte
  lte

  @@map("pricing_rule_operator")
}

enum WooAuthMethod {
  public_store_api
  consumer_keys

  @@map("woo_auth_method")
}

enum ValidationSeverity {
  Critical
  Warning
  Info

  @@map("validation_severity")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String @db.VarChar(120)
  tenantName   String @map("tenant_name") @db.VarChar(160)
  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)

  @@map("users")
}

model IntegrationConnection {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionName          String        @map("connection_name") @db.VarChar(120)
  storeUrl                String        @map("store_url") @db.VarChar(255)
  restApiBase             String        @map("rest_api_base") @db.VarChar(255)
  authMethod              WooAuthMethod @map("auth_method")
  consumerKey             String?       @map("consumer_key") @db.VarChar(255)
  consumerSecret          String?       @map("consumer_secret") @db.VarChar(255)
  apiStatus               String        @default("Not tested") @map("api_status") @db.VarChar(80)
  lastSync                DateTime?     @map("last_sync")
  mode                    String        @default("Manual sync with audit trail") @db.VarChar(120)
  importPublishedProducts Boolean       @default(true) @map("import_published_products")
  importAttributes        Boolean       @default(true) @map("import_attributes")
  importVariations        Boolean       @default(true) @map("import_variations")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  syncedProducts Product[]

  @@map("integration_connections")
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionId     String   @map("connection_id") @db.Uuid
  wooProductId     BigInt   @map("woo_product_id")
  name             String   @db.VarChar(255)
  category         String   @db.VarChar(255)
  status           String   @db.VarChar(80)
  sku              String   @db.VarChar(255)
  basePrice        String   @map("base_price") @db.VarChar(80)
  width            Decimal? @db.Decimal(10, 2)
  height           Decimal? @db.Decimal(10, 2)
  importedFields   Json?    @map("imported_fields")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  optionsContainers ProductOptionsContainer[]

  @@unique([connectionId, wooProductId], name: "uq_synced_product_connection_woo_id")
  @@index([connectionId])
  @@map("synced_products")
}


// ─── Product Options ─────────────────────────────────────────────────────────

model OptionsContainer {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String @db.VarChar(120)

  products ProductOptionsContainer[]
  items    OptionItem[]

  @@map("options_containers")
}

model ProductOptionsContainer {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId          String @map("product_id") @db.Uuid
  optionsContainerId String @map("options_container_id") @db.Uuid

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionsContainer OptionsContainer @relation(fields: [optionsContainerId], references: [id], onDelete: Cascade)

  @@unique([productId, optionsContainerId], name: "uq_product_options_container")
  @@index([optionsContainerId])
  @@map("product_options_containers")
}

model OptionsGroup {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(120)

  items OptionItem[]

  @@map("options_groups")
}

model OptionItem {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  optionsContainerId String  @map("options_container_id") @db.Uuid
  optionGroupId      String  @map("option_group_id") @db.Uuid
  name               String  @db.VarChar(120)
  slug               String  @db.VarChar(120)
  priceUnit          Decimal @map("price_unit") @db.Decimal(12, 4)
  length             Int?    @map("process_length_mm")
  width              Int?    @map("process_width_mm")
  calculationBasis   String  @map("calculation_basis") @db.VarChar(80)
  displayMode        String  @default("SELECTABLE") @map("display_mode") @db.VarChar(20)

  optionsContainer OptionsContainer @relation(fields: [optionsContainerId], references: [id], onDelete: Cascade)
  optionGroup      OptionsGroup     @relation(fields: [optionGroupId], references: [id])

  @@unique([optionsContainerId, slug], name: "uq_option_item_container_slug")
  @@index([optionsContainerId])
  @@index([optionGroupId])
  @@map("option_items")
}
