generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OptionType {
  select
  boolean
  integer
  decimal

  @@map("option_type")
}

enum PricingRuleType {
  flat_surcharge
  percentage
  quantity_discount

  @@map("pricing_rule_type")
}

enum PricingRuleOperator {
  eq
  gte
  lte

  @@map("pricing_rule_operator")
}

enum CalculationBasis {
  YIELD_PCS
  LINEAR_M
  SQM
  PERIMETER
  PCS
  ORDER
  FREE

  @@map("calculation_basis")
}

enum ContainerType {
  SINGLE_SELECT
  MULTI_SELECT
  AUTO_APPLIED
}


enum WooAuthMethod {
  public_store_api
  consumer_keys

  @@map("woo_auth_method")
}

enum ValidationSeverity {
  Critical
  Warning
  Info

  @@map("validation_severity")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String @db.VarChar(120)
  tenantName   String @map("tenant_name") @db.VarChar(160)
  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)

  @@map("users")
}

model IntegrationConnection {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionName          String        @map("connection_name") @db.VarChar(120)
  storeUrl                String        @map("store_url") @db.VarChar(255)
  restApiBase             String        @map("rest_api_base") @db.VarChar(255)
  authMethod              WooAuthMethod @map("auth_method")
  consumerKey             String?       @map("consumer_key") @db.VarChar(255)
  consumerSecret          String?       @map("consumer_secret") @db.VarChar(255)
  apiStatus               String        @default("Not tested") @map("api_status") @db.VarChar(80)
  lastSync                DateTime?     @map("last_sync")
  mode                    String        @default("Manual sync with audit trail") @db.VarChar(120)
  importPublishedProducts Boolean       @default(true) @map("import_published_products")
  importAttributes        Boolean       @default(true) @map("import_attributes")
  importVariations        Boolean       @default(true) @map("import_variations")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  syncedProducts Product[]

  @@map("integration_connections")
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionId     String   @map("connection_id") @db.Uuid
  wooProductId     BigInt   @map("woo_product_id")
  name             String   @db.VarChar(255)
  category         String   @db.VarChar(255)
  status           String   @db.VarChar(80)
  sku              String   @db.VarChar(255)
  basePrice        String   @map("base_price") @db.VarChar(80)
  width            Decimal? @db.Decimal(10, 2)
  height           Decimal? @db.Decimal(10, 2)
  importedFields   Json?    @map("imported_fields")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  containers  OptionsContainer[]
  printAreaConfig ProductPrintAreaConfig?

  @@unique([connectionId, wooProductId], name: "uq_synced_product_connection_woo_id")
  @@index([connectionId])
  @@map("synced_products")
}

model ProductPrintAreaConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @unique @map("product_id") @db.Uuid
  views     Json     @map("views_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_print_area_configs")
}


// ─── Price Item Library ───────────────────────────────────────────────────────

model OptionsGroup {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(120)

  items OptionItem[]

  @@map("options_groups")
}

model OptionItem {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId          String?          @map("group_id") @db.Uuid
  name             String           @unique @db.VarChar(120)
  slug             String           @unique @db.VarChar(120)
  priceUnit        Decimal          @map("price_unit") @db.Decimal(12, 4)
  lengthMm         Int?             @map("process_length_mm")
  widthMm          Int?             @map("process_width_mm")
  calculationBasis CalculationBasis @map("calculation_basis")

  group              OptionsGroup?        @relation(fields: [groupId], references: [id])
  containerItems     ContainerOptionItem[]
  defaultForContainers OptionsContainer[] @relation("ContainerDefault")

  @@index([groupId])
  @@map("option_items")
}

// ─── Product Pricing Setup ────────────────────────────────────────────────────

model OptionsContainer {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String  @map("product_id") @db.Uuid
  name          String  @db.VarChar(120)
  sortOrder     Int     @default(0) @map("sort_order")
  defaultItemId String? @map("default_item_id") @db.Uuid
  containerType  ContainerType
  isHidden       Boolean       @default(false) @map("is_hidden")
  isRequired     Boolean       @default(false) @map("is_required")

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  defaultItem OptionItem? @relation("ContainerDefault", fields: [defaultItemId], references: [id])
  items       ContainerOptionItem[]

  @@index([productId])
  @@map("options_containers")
}

// Item slot inside a container — settings can be overridden per container
model ContainerOptionItem {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  containerId   String  @map("container_id") @db.Uuid
  itemId        String  @map("item_id") @db.Uuid
  sortOrder     Int     @default(0) @map("sort_order")
  priceUnit     Decimal? @map("price_unit") @db.Decimal(12, 4)
  name String? 

  container OptionsContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)
  item      OptionItem       @relation(fields: [itemId], references: [id])

  @@unique([containerId, itemId], name: "uq_container_option_item")
  @@index([itemId])
  @@map("container_option_items")
}

