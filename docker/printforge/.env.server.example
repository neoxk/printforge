POSTGRES_DB=printforge
POSTGRES_USER=printforge
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://printforge:change-me@postgres:5432/printforge

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me

PORT=3000
NODE_ENV=production

# Optional. Set this only if Fastify should contact WordPress through Docker DNS
# while the admin UI should still display a public/storefront URL.
# WOOCOMMERCE_INTERNAL_URL=http://wordpress

# S3 object storage
S3_ENDPOINT=https://hel1.your-objectstorage.com
S3_BUCKET=printforge
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
